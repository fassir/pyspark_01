          "rawSql": "SELECT ingestion_time AS \"time\", symbol, ROUND(((price_usd - AVG(price_usd) OVER (PARTITION BY symbol)) / NULLIF(STDDEV(price_usd) OVER (PARTITION BY symbol), 0))::numeric, 3) AS z_score FROM crypto_price_history WHERE symbol IN ($symbol) AND $__timeFilter(ingestion_time) ORDER BY ingestion_time",

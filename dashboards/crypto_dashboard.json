      "title": "Anomaly Feed — Z-Score Detection ($symbol)",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "crypto_pg_01" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "color-text" }, "inspect": false },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "z_score" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green" },
                    { "color": "yellow", "value": 1.5 },
                    { "color": "red", "value": 2 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "price_usd" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }]
          },
          {
            "matcher": { "id": "byName", "options": "global_avg" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }]
          },
          {
            "matcher": { "id": "byName", "options": "is_anomaly" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "false": { "color": "green", "index": 1, "text": "normal" },
                      "true": { "color": "red", "index": 0, "text": "ANOMALY" }
                    },
                    "type": "value"
                  }
                ]
              },
              { "id": "custom.cellOptions", "value": { "mode": "gradient", "type": "color-background" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 52 },
      "id": 17,
      "options": { "footer": { "fields": "", "reducer": ["sum"], "show": false }, "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "crypto_pg_01" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ingestion_time, symbol, price_usd, ROUND(AVG(price_usd) OVER (PARTITION BY symbol)::numeric, 2) AS global_avg, ROUND(((price_usd - AVG(price_usd) OVER (PARTITION BY symbol)) / NULLIF(STDDEV(price_usd) OVER (PARTITION BY symbol), 0))::numeric, 3) AS z_score, ABS((price_usd - AVG(price_usd) OVER (PARTITION BY symbol)) / NULLIF(STDDEV(price_usd) OVER (PARTITION BY symbol), 0)) > 2 AS is_anomaly FROM crypto_price_history WHERE symbol IN ($symbol) ORDER BY ABS((price_usd - AVG(price_usd) OVER (PARTITION BY symbol)) / NULLIF(STDDEV(price_usd) OVER (PARTITION BY symbol), 0)) DESC NULLS LAST LIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Recent Anomaly Events — $symbol",
      "type": "table"
    },

          "rawSql": "SELECT \n  $__timeGroup(ingestion_time, '15m') as \"time\", \n  symbol,\n  min(price_usd) as \"low\", \n  max(price_usd) as \"high\", \n  (array_agg(price_usd ORDER BY ingestion_time ASC))[1] as \"open\", \n  (array_agg(price_usd ORDER BY ingestion_time DESC))[1] as \"close\" \nFROM crypto_price_history \nWHERE symbol IN ($symbol) AND $__timeFilter(ingestion_time) \nGROUP BY 1, 2 \nORDER BY 1, 2",
